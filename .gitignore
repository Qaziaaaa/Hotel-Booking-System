# ============================================================
# Root .gitignore — Hotel Booking System
# ============================================================

# ── Dependencies ────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Environment variables (NEVER commit real secrets) ───────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# ── Build outputs ───────────────────────────────────────────
dist/
build/
.next/
out/

# ── Logs ────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Runtime / OS ────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor / IDE ────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Prisma ──────────────────────────────────────────────────
# Keep migrations and schema; ignore generated client
server/node_modules/

# ── Test coverage ───────────────────────────────────────────
coverage/
.nyc_output/

# ── Misc ────────────────────────────────────────────────────
*.tgz
*.zip
.cache/
.parcel-cache/
.turbo/
